# =============================================================================
# Healium — Environment Configuration
# =============================================================================
# The system is LOCAL-FIRST by default.
# All three agents run on your local Ollama instance with no API calls needed.
#
# LOCAL MODELS (default — no keys required)
# -----------------------------------------
# OLLAMA_MODEL      = model used for tool-calling agents (Architect + Analyzer)
# OLLAMA_FAST_MODEL = model used for the Liaison report-writer (no tool-calling)
#
OLLAMA_MODEL=llama3.1
OLLAMA_FAST_MODEL=qwen2.5:3b

# Set USE_OLLAMA=true to FORCE local inference even if API keys are present below.
USE_OLLAMA=true

# =============================================================================
# OPTIONAL: Cloud API override
# Uncomment and fill in ONE key to route ALL agents through that cloud provider.
# Only takes effect when USE_OLLAMA is NOT set to "true".
# =============================================================================
# GROQ_API_KEY=your_groq_api_key_here        # Free tier, fast llama-3.3-70b
# OPENAI_API_KEY=your_openai_api_key_here    # GPT-4o
# GOOGLE_API_KEY=your_google_api_key_here    # Gemini 1.5 Pro
